    {
      "name": "3) Valid request with reviews=true query param",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Movie response includes reviews array', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.be.an('object');",
              "    pm.expect(json).to.have.property('movie');",
              "    pm.expect(json.movie).to.have.property('reviews');",
              "    pm.expect(json.movie.reviews).to.be.an('array');",
              "    if (json.movie._id) pm.collectionVariables.set('movieId', json.movie._id);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "https://csci-3916-hw4.onrender.com/{{movieParam}}?reviews=true",
          "protocol": "https",
          "host": [
            "csci-3916-hw4",
            "onrender",
            "com"
          ],
          "path": [
            "{{movieParam}}"
          ],
          "query": [
            {
              "key": "reviews",
              "value": "true"
            }
          ]
        }
      },
      "response": []
    },
